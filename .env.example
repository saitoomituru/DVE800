# DVE800 環境変数テンプレート
# cp .env.example .env して編集してください

# DaVinci Resolve Python APIモジュールのパス
# macOS デフォルト例:
# DAVINCI_MODULE_PATH=/Library/Application Support/Blackmagic Design/DaVinci Resolve/Developer/Scripting/Modules
# Linux デフォルト例:
# DAVINCI_MODULE_PATH=/opt/resolve/Developer/Scripting/Modules
DAVINCI_MODULE_PATH=

# FAM語彙ディレクトリ（デフォルト: ./fam_vocab）
FAM_VOCAB_DIR=./fam_vocab

# Whisper設定
WHISPER_MODEL_SIZE=large-v3
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=int8

# OND800 リモートWhisperサーバー（任意）
# OND800_WHISPER_URL=http://ond800.local:8000
OND800_WHISPER_URL=

# ログレベル（DEBUG / INFO / WARNING / ERROR）
LOG_LEVEL=INFO
